{
  "name": "nexus",
  "version": "0.1.0",
  "description": "Local-first automatic link discovery for Obsidian",
  "main": "main.js",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc --noEmit --skipLibCheck && node esbuild.config.mjs production",
    "test": "jest",
    "eval": "ts-node --compiler-options '{\"module\":\"CommonJS\",\"moduleResolution\":\"node\",\"esModuleInterop\":true}' scripts/eval-resolvers.ts",
    "eval:span-lcs": "npm run eval -- --extractor=span --resolver=lcs",
    "eval:span-arctic": "npm run eval -- --extractor=span --resolver=arctic",
    "eval:span-gemma": "npm run eval -- --extractor=span --resolver=gemma",
    "eval:yake-lcs": "npm run eval -- --extractor=yake --resolver=lcs",
    "eval:yake-arctic": "npm run eval -- --extractor=yake --resolver=arctic",
    "eval:yake-gemma": "npm run eval -- --extractor=yake --resolver=gemma",
    "eval:span": "npm run eval -- --extractor=span",
    "eval:yake": "npm run eval -- --extractor=yake",
    "eval:lcs": "npm run eval -- --resolver=lcs",
    "eval:arctic": "npm run eval -- --resolver=arctic",
    "eval:gemma": "npm run eval -- --resolver=gemma"
  },
  "author": "Tony Wang",
  "license": "MIT",
  "dependencies": {
    "compromise": "^14.14.3"
  },
  "devDependencies": {
    "@huggingface/transformers": "^4.0.1",
    "@types/jest": "^29.5.0",
    "@types/node": "^20.0.0",
    "builtin-modules": "^3.3.0",
    "esbuild": "^0.24.0",
    "jest": "^29.7.0",
    "obsidian": "latest",
    "ts-jest": "^29.2.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.0"
  }
}
