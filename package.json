{
  "name": "nexus",
  "version": "0.1.0",
  "description": "Local-first automatic link discovery for Obsidian",
  "main": "main.js",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc --noEmit --skipLibCheck && node esbuild.config.mjs production",
    "test": "jest",
    "eval": "ts-node --compiler-options '{\"module\":\"CommonJS\",\"moduleResolution\":\"node\",\"esModuleInterop\":true,\"resolveJsonModule\":true}' scripts/eval-resolvers.ts",
    "eval:span-lcs": "npm run eval -- --extractor=span --resolver=lcs",
    "eval:span-arctic": "npm run eval -- --extractor=span --resolver=arctic",
    "eval:span-gemma": "npm run eval -- --extractor=span --resolver=gemma",
    "eval:yake-lcs": "npm run eval -- --extractor=yake --resolver=lcs",
    "eval:yake-arctic": "npm run eval -- --extractor=yake --resolver=arctic",
    "eval:yake-gemma": "npm run eval -- --extractor=yake --resolver=gemma",
    "eval:span": "npm run eval -- --extractor=span",
    "eval:yake": "npm run eval -- --extractor=yake",
    "eval:lcs": "npm run eval -- --resolver=lcs",
    "eval:arctic": "npm run eval -- --resolver=arctic",
    "eval:gemma": "npm run eval -- --resolver=gemma",
    "eval:sparse": "npm run eval -- --resolver=sparse",
    "eval:span-sparse": "npm run eval -- --extractor=span --resolver=sparse",
    "eval:yake-sparse": "npm run eval -- --extractor=yake --resolver=sparse",
    "wiki:prepare": "ts-node --compiler-options '{\"module\":\"CommonJS\",\"moduleResolution\":\"node\",\"esModuleInterop\":true}' scripts/prepare-wiki-corpus.ts",
    "corpus:build-sentences": "ts-node --compiler-options '{\"module\":\"CommonJS\",\"moduleResolution\":\"node\",\"esModuleInterop\":true}' scripts/build-corpus-sentences.ts",
    "corpus:merge": "ts-node --compiler-options '{\"module\":\"CommonJS\",\"moduleResolution\":\"node\",\"esModuleInterop\":true}' scripts/merge-corpora.ts",
    "wiki:embed": "ts-node --compiler-options '{\"module\":\"CommonJS\",\"moduleResolution\":\"node\",\"esModuleInterop\":true}' scripts/embed-corpus.ts",
    "wiki:embed-25k": "ts-node --compiler-options '{\"module\":\"CommonJS\",\"moduleResolution\":\"node\",\"esModuleInterop\":true}' scripts/embed-corpus.ts --input=data/wiki/corpus-25k.txt --output=data/wiki/embeddings-25k.f32.bin --manifest=data/wiki/embeddings-25k-manifest.json --device=coreml --batch-size=512",
    "wiki:embed-100k": "ts-node --compiler-options '{\"module\":\"CommonJS\",\"moduleResolution\":\"node\",\"esModuleInterop\":true}' scripts/embed-corpus.ts --input=data/wiki/corpus-100k.txt --output=data/wiki/embeddings-100k.f32.bin --manifest=data/wiki/embeddings-100k-manifest.json --device=coreml --batch-size=512",
    "wiki:embed:sharded": "bash scripts/wiki-embed-sharded.sh",
    "wiki:split-corpus": "ts-node --compiler-options '{\"module\":\"CommonJS\",\"moduleResolution\":\"node\",\"esModuleInterop\":true}' scripts/split-corpus-shards.ts",
    "wiki:embed:merge-shards": "ts-node --compiler-options '{\"module\":\"CommonJS\",\"moduleResolution\":\"node\",\"esModuleInterop\":true}' scripts/merge-embedding-shards.ts",
    "train:sae": "ts-node --compiler-options '{\"module\":\"CommonJS\",\"moduleResolution\":\"node\",\"esModuleInterop\":true}' scripts/train-sae.ts",
    "vocab:build": "ts-node --compiler-options '{\"module\":\"CommonJS\",\"moduleResolution\":\"node\",\"esModuleInterop\":true}' scripts/build-vocab.ts",
    "vocab:fetch": "ts-node --compiler-options '{\"module\":\"CommonJS\",\"moduleResolution\":\"node\",\"esModuleInterop\":true}' scripts/build-vocab.ts --fetch",
    "vocab:embed": "ts-node --compiler-options '{\"module\":\"CommonJS\",\"moduleResolution\":\"node\",\"esModuleInterop\":true}' scripts/embed-vocab.ts",
    "train:sae-modal": "modal run scripts/modal_train_sae_v2.py --vocab data/vocab.txt --out-dir ./modal-out-v2",
    "label:autointerp": "modal run scripts/modal_autointerp_vocab.py --weights assets/sae-weights-v2.bin --out assets/sae-feature-labels-v2.json",
    "label:autointerp:broad": "modal run scripts/modal_autointerp_vocab.py --weights assets/sae-weights-v2.bin --out assets/sae-feature-labels-v2.json --broad-vocab",
    "bench:runtime": "ts-node --compiler-options '{\"module\":\"CommonJS\",\"moduleResolution\":\"node\",\"esModuleInterop\":true,\"resolveJsonModule\":true}' scripts/benchmark-runtime.ts",
    "bench:runtime:quick": "npm run bench:runtime -- --sample=20",
    "bench:runtime:full": "npm run bench:runtime -- --sweep=all"
  },
  "author": "Tony Wang",
  "license": "MIT",
  "dependencies": {
    "compromise": "^14.14.3"
  },
  "devDependencies": {
    "@huggingface/transformers": "^4.0.1",
    "@tensorflow/tfjs-node": "^4.22.0",
    "@types/cli-progress": "^3.11.6",
    "@types/jest": "^29.5.0",
    "@types/node": "^20.0.0",
    "@types/sax": "^1.2.7",
    "builtin-modules": "^3.3.0",
    "cli-progress": "^3.12.0",
    "esbuild": "^0.24.0",
    "jest": "^29.7.0",
    "obsidian": "latest",
    "sax": "^1.6.0",
    "ts-jest": "^29.2.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.0"
  }
}
